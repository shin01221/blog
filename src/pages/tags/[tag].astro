---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).filter((post) => !post.data.draft);

  const tagSet = new Set<string>();
  allPosts.forEach((post) => {
    post.data.tags?.forEach((tag) => tagSet.add(tag));
  });

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags?.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = '/blog';
---

<BaseLayout title={`#${tag} — Medhat's Blog`} description={`Posts tagged with "${tag}".`}>
  <a href={base + '/tags'} class="back-link">&larr; All tags</a>

  <div class="about-container">
    <h1>#{tag}</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-lg);">{posts.length} post{posts.length !== 1 ? 's' : ''} tagged with "{tag}"</p>

    <div style="display: flex; flex-direction: column; gap: var(--space-md);">
      {posts.map((post: any) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
        />
      ))}
    </div>
  </div>
</BaseLayout>
