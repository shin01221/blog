---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).filter((post) => !post.data.draft);

  const tagSet = new Set<string>();
  allPosts.forEach((post) => {
    post.data.tags?.forEach((tag) => tagSet.add(tag));
  });

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags?.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} — Medhat's Blog`} description={`Posts tagged with "${tag}".`}>
  <div class="animate-in">
    <a href="/tags" class="back-link">
      <span>←</span> All tags
    </a>

    <div class="about-header">
      <h1>#{tag}</h1>
      <p>{posts.length} post{posts.length !== 1 ? 's' : ''} tagged with "{tag}"</p>
    </div>

    <div class="post-grid">
      {posts.map((post: any, index: number) => (
        <div class={`animate-in animate-delay-${Math.min(index + 1, 3)}`}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
