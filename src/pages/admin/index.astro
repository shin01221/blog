---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin — Medhat's Blog" description="Blog administration panel.">
  <div class="admin-container animate-in" id="admin-app">
    <div class="about-header">
      <h1>Admin Panel</h1>
      <p>Create and manage blog posts</p>
    </div>

    <!-- Login Section -->
    <div id="login-section" class="admin-login">
      <div class="admin-form">
        <div class="form-group">
          <label for="admin-key">Admin Access Key</label>
          <input type="password" id="admin-key" placeholder="Enter your admin key..." />
        </div>
        <button class="btn btn-primary" id="login-btn" style="width: 100%;">
          🔓 Authenticate
        </button>
        <div id="login-status"></div>
      </div>
    </div>

    <!-- Admin Dashboard (hidden until authenticated) -->
    <div id="dashboard-section" style="display: none;">
      <!-- Create Post Form -->
      <div class="admin-form" style="margin-bottom: var(--space-xl);">
        <h3 style="margin-bottom: var(--space-lg); font-size: var(--font-size-lg);">📝 Create New Post</h3>

        <div class="form-group">
          <label for="post-title">Title</label>
          <input type="text" id="post-title" placeholder="My Awesome Blog Post" />
        </div>

        <div class="form-group">
          <label for="post-description">Description</label>
          <input type="text" id="post-description" placeholder="A brief description of your post..." />
        </div>

        <div class="form-group">
          <label for="post-tags">Tags (comma-separated)</label>
          <input type="text" id="post-tags" placeholder="cybersecurity, linux, tools" />
        </div>

        <div class="form-group">
          <label for="post-author">Author</label>
          <input type="text" id="post-author" placeholder="Medhat" value="Medhat" />
        </div>

        <div class="form-group">
          <label for="post-body">Content (Markdown)</label>
          <textarea id="post-body" placeholder="Write your post in Markdown...

## Introduction

Your content here...

```python
print('Hello, World!')
```
"></textarea>
        </div>

        <div style="display: flex; gap: var(--space-sm);">
          <button class="btn btn-primary" id="create-btn">
            🚀 Publish Post
          </button>
          <button class="btn btn-secondary" id="preview-btn">
            👁️ Preview
          </button>
        </div>

        <div id="create-status"></div>
      </div>

      <!-- Existing Posts -->
      <div class="admin-form">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-lg);">
          <h3 style="font-size: var(--font-size-lg);">📋 Existing Posts</h3>
          <button class="btn btn-secondary" id="refresh-btn" style="padding: var(--space-xs) var(--space-md);">
            🔄 Refresh
          </button>
        </div>
        <div id="posts-list">
          <p style="color: var(--color-text-muted); text-align: center;">Loading posts...</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const API_BASE = '/.netlify/functions';
  let adminKey = '';

  // Elements
  const loginSection = document.getElementById('login-section');
  const dashboardSection = document.getElementById('dashboard-section');
  const loginBtn = document.getElementById('login-btn');
  const loginStatus = document.getElementById('login-status');
  const adminKeyInput = document.getElementById('admin-key');
  const createBtn = document.getElementById('create-btn');
  const createStatus = document.getElementById('create-status');
  const refreshBtn = document.getElementById('refresh-btn');
  const postsList = document.getElementById('posts-list');

  // Check for saved key
  const savedKey = localStorage.getItem('adminKey');
  if (savedKey) {
    adminKey = savedKey;
    showDashboard();
  }

  // Login
  loginBtn?.addEventListener('click', () => {
    const key = adminKeyInput?.value?.trim();
    if (!key) {
      showStatus(loginStatus, 'Please enter an access key.', 'error');
      return;
    }
    adminKey = key;
    localStorage.setItem('adminKey', key);
    showDashboard();
  });

  adminKeyInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') loginBtn?.click();
  });

  function showDashboard() {
    if (loginSection) loginSection.style.display = 'none';
    if (dashboardSection) dashboardSection.style.display = 'block';
    loadPosts();
  }

  // Create Post
  createBtn?.addEventListener('click', async () => {
    const title = document.getElementById('post-title')?.value?.trim();
    const description = document.getElementById('post-description')?.value?.trim();
    const tagsRaw = document.getElementById('post-tags')?.value?.trim();
    const author = document.getElementById('post-author')?.value?.trim() || 'Medhat';
    const body = document.getElementById('post-body')?.value?.trim();

    if (!title || !description || !body) {
      showStatus(createStatus, 'Title, description, and content are required.', 'error');
      return;
    }

    const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : [];

    createBtn.disabled = true;
    createBtn.textContent = '⏳ Publishing...';

    try {
      const res = await fetch(`${API_BASE}/create-post`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${adminKey}`,
        },
        body: JSON.stringify({ title, description, tags, author, body }),
      });

      const data = await res.json();

      if (res.ok) {
        showStatus(createStatus, `✅ Post "${title}" published! Site rebuild triggered.`, 'success');
        // Clear form
        document.getElementById('post-title').value = '';
        document.getElementById('post-description').value = '';
        document.getElementById('post-tags').value = '';
        document.getElementById('post-body').value = '';
        loadPosts();
      } else {
        showStatus(createStatus, `❌ ${data.error || 'Failed to create post.'}`, 'error');
        if (res.status === 401) {
          localStorage.removeItem('adminKey');
        }
      }
    } catch (err) {
      showStatus(createStatus, `❌ Network error: ${err.message}`, 'error');
    } finally {
      createBtn.disabled = false;
      createBtn.textContent = '🚀 Publish Post';
    }
  });

  // Load Posts
  async function loadPosts() {
    try {
      const res = await fetch(`${API_BASE}/list-posts`, {
        headers: { 'Authorization': `Bearer ${adminKey}` },
      });

      if (res.status === 401) {
        postsList.innerHTML = '<p style="color: var(--color-text-muted);">Invalid admin key. Please re-authenticate.</p>';
        localStorage.removeItem('adminKey');
        if (dashboardSection) dashboardSection.style.display = 'none';
        if (loginSection) loginSection.style.display = 'block';
        return;
      }

      const data = await res.json();

      if (data.posts && data.posts.length > 0) {
        postsList.innerHTML = data.posts.map(post => `
          <div class="admin-post-item">
            <div>
              <h4>${post.title}</h4>
              <span>${post.date} · ${post.slug}</span>
            </div>
            <button class="btn btn-danger" onclick="deletePost('${post.slug}')" style="padding: 4px 12px; font-size: 0.75rem;">
              🗑️ Delete
            </button>
          </div>
        `).join('');
      } else {
        postsList.innerHTML = '<p style="color: var(--color-text-muted); text-align: center;">No posts in Netlify Blobs. Local markdown posts are not listed here.</p>';
      }
    } catch (err) {
      postsList.innerHTML = `<p style="color: var(--color-text-muted); text-align: center;">Could not load posts. Functions may not be available locally.</p>`;
    }
  }

  // Delete Post
  window.deletePost = async function(slug) {
    if (!confirm(`Delete post "${slug}"?`)) return;

    try {
      const res = await fetch(`${API_BASE}/delete-post`, {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${adminKey}`,
        },
        body: JSON.stringify({ slug }),
      });

      if (res.ok) {
        loadPosts();
      } else {
        const data = await res.json();
        alert(`Error: ${data.error || 'Failed to delete post.'}`);
      }
    } catch (err) {
      alert(`Network error: ${err.message}`);
    }
  };

  refreshBtn?.addEventListener('click', loadPosts);

  function showStatus(el, message, type) {
    if (!el) return;
    el.innerHTML = `<div class="status status-${type}">${message}</div>`;
    setTimeout(() => { el.innerHTML = ''; }, 5000);
  }
</script>
